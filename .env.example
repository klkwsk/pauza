# Skopiuj do .env.local i uzupełnij wartościami. NIE commituj .env.local.

# Supabase — publiczne (bezpieczne w przeglądarce)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — sekret (service-role). TYLKO server-side. Wymagany przez /api/v1/* i MCP.
SUPABASE_SECRET_KEY=

# Anthropic — odpowiedzi Eksperta (model claude-haiku-4-5)
ANTHROPIC_API_KEY=

# OpenAI — embeddingi do wyszukiwania hybrydowego (RAG). Opcjonalny (jest fallback).
OPENAI_API_KEY=
